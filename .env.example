# Template for local .env.local (gitignored). Copy this file:
#   cp .env.example .env.local
# In production / preview these are managed through `vercel env`
# (separate per-environment values). Reference: NFR-SEC-02 in docs/prd.md.

# === Auto-provisioned by Vercel integrations ===
# Pull with `vercel env pull .env.local` after `vercel link`.

# Neon Postgres (provisioned via Vercel Marketplace, ADR D-024).
POSTGRES_URL=

# Vercel Blob (signed PDF storage, ADR D-028).
BLOB_READ_WRITE_TOKEN=

# === Manually set ===

# PrivatBank Автоклієнт API token (Slice 6: payments-ingest).
PRIVATBANK_TOKEN=

# Рахунок ФОПа, з якого PrivatBank Автоклієнт API тягне виписку платежів.
# Передається як `acc` у запит до acp.privatbank.ua (lib/external-apis/privatbank).
# УВАГА: це НЕ те саме, що `bankAccount` у реквізитах акту (Налаштування →
# Реквізити, ключ `fop_requisites`). Фізично це один рахунок, але зберігається
# у двох місцях для двох різних споживачів і формат може відрізнятися (тут —
# ідентифікатор рахунку для PrivatBank API; у реквізитах — IBAN для друку в акті).
# Без цієї змінної polling платежів падає — НЕ видаляти при міграції FOP_* у реквізити.
FOP_BANK_ACCOUNT=

# Дубідок API token, Premium tier (Slice 9: edo-dubidoc, ADR D-029).
# Passed in X-Access-Token header. Create in my.dubidoc.com.ua → Мої організації → API ключ.
DUBIDOC_TOKEN=

# Дубідок organization UUID (X-Organization header, required for POST /documents).
# Copy from the same "Мої організації" page.
DUBIDOC_ORGANIZATION_ID=

# MoeOSBB sync endpoint URL (PHP on shared hosting, reads from replica DB;
# Slice 11: moeosbb-sync). Example: https://moeosbb-sync.example.com/api.php
MOEOSBB_SYNC_URL=

# MoeOSBB sync Bearer token. Generate: openssl rand -hex 32
# Must match the token in the PHP endpoint on the hosting.
MOEOSBB_SYNC_TOKEN=

# Single admin login (BC-USER-01, ADR D-032).
# Example: ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL=
# argon2id hash (NFR-SEC-03). Generate locally:
#   printf 'your-password' | node scripts/hash-password.mjs
# Output shape: $argon2id$v=19$m=65536,t=3,p=1$<salt>$<hash>
ADMIN_PASSWORD_HASH=

# Session cookie signing secret (≥ 32 random bytes). Generate locally:
#   openssl rand -base64 48
# Rotating this invalidates every existing session cookie.
SESSION_SECRET=

# ФОП executor details for the ACT (name, ІПН, address, bank account, phone,
# email, city) live in the admin Settings → Реквізити section (settings table,
# key `fop_requisites`), not in env. See ADR D-005 / openspec specs/requisites.
# Виняток — рахунок ФОПа для PrivatBank polling (`FOP_BANK_ACCOUNT` вище),
# який лишається env-змінною, бо потрібен інтеграції до того, як зчитуються
# реквізити з БД, і є технічним параметром API, а не друкованим реквізитом.

# === Optional ===

# When true, external API request/response bodies are logged at debug level
# (NFR-LOG-04). Leave unset in production.
DEBUG_API=
