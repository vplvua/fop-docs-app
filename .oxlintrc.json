{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "react-perf",
    "jsx-a11y",
    "nextjs",
    "import",
    "promise"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "pedantic": "warn",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": [
      "error",
      {
        "allow": [
          "**/*.css",
          "**/*.scss",
          "@testing-library/jest-dom/**",
          "server-only",
          "client-only"
        ]
      }
    ]
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true,
    "builtin": true
  },
  "overrides": [
    {
      "files": ["tests/**/*", "**/*.test.{ts,tsx}", "**/*.spec.{ts,tsx}"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["scripts/**/*.{js,mjs,cjs}"],
      "rules": {
        "no-console": "off",
        "no-await-in-loop": "off"
      }
    }
  ]
}
